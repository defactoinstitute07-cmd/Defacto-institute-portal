{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/backend/server.js"
        },
        {
            "source": "/admin/:path*",
            "destination": "/backend/server.js"
        },
        {
            "source": "/uploads/:path*",
            "destination": "/backend/server.js"
        },
        {
            "source": "/((?!api|admin|uploads).*)",
            "destination": "/frontend/index.html"
        }
    ]
}