# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- MongoDB ---
# Get this from MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority

# --- JWT Secret ---
# Any long random string (min 32 chars) for signing tokens
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters

# --- Node Environment ---
NODE_ENV=development

# --- Cloudinary (Optional - for image uploads) ---
# Get from cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email (Brevo SMTP - Primary, recommended) ---
# Get from Brevo > Transactional > Settings > SMTP & API
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_KEY=your_brevo_smtp_key

# --- Email (Gmail SMTP - Fallback) ---
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# --- CORS (for production) ---
# Your frontend Vercel URL
CORS_ORIGIN=https://your-frontend.vercel.app

# --- Redis (Optional - for caching) ---
# REDIS_URL=redis://...
