{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "fluid": true,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ]
}
